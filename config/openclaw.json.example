{
  "env": {
    "ZHIPU_API_KEY": "YOUR_ZHIPU_API_KEY_HERE",
    "YITONG_API_KEY": "YOUR_YITONG_API_KEY_HERE"
  },
  "logging": {
    "level": "fatal"
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://localhost:11434/v1",
        "models": [
          {
            "id": "jarvis-learned",
            "name": "Jarvis Learned",
            "contextWindow": 4718592,
            "maxTokens": 4096
          },
          {
            "id": "jarvis",
            "name": "Jarvis",
            "contextWindow": 32768,
            "maxTokens": 4096
          }
        ]
      },
      "yitong": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "YOUR_YITONG_API_KEY_HERE",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3-max",
            "name": "Qwen3-Max",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "agnes-ai": {
        "baseUrl": "https://apihub.agnes-ai.com/v1",
        "apiKey": "YOUR_AGNES_API_KEY_HERE",
        "api": "openai-completions",
        "models": [
          {
            "id": "agnes-2.0-flash",
            "name": "Agnes 2.0 Flash",
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "agnes-1.5-flash",
            "name": "Agnes 1.5 Flash",
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "agnes-ai/agnes-2.0-flash",
        "fallbacks": [
          "agnes-ai/agnes-1.5-flash"
        ]
      },
      "maxConcurrent": 4
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "channels": {
    "discord": {
      "enabled": false,
      "token": "YOUR_DISCORD_BOT_TOKEN_HERE",
      "allowBots": true,
      "groupPolicy": "open",
      "dm": {
        "enabled": true,
        "policy": "allowlist"
      }
    },
    "feishu": {
      "enabled": false,
      "appId": "YOUR_FEISHU_APP_ID_HERE",
      "appSecret": "YOUR_FEISHU_APP_SECRET_HERE",
      "groupPolicy": "open"
    },
    "openclaw-weixin": {
      "dmPolicy": "open",
      "groupPolicy": "open",
      "actions": {
        "reactions": true,
        "sendMessage": true,
        "polls": true,
        "stickers": true,
        "emojiUploads": true,
        "stickerUploads": true,
        "permissions": true,
        "messages": true,
        "threads": true,
        "pins": true,
        "search": true,
        "memberInfo": true,
        "roleInfo": true,
        "roles": true,
        "channelInfo": true,
        "voiceStatus": true,
        "events": true,
        "moderation": true,
        "channels": true
      },
      "allowFrom": [
        "*"
      ],
      "groupAllowFrom": [
        "*"
      ],
      "inbound": {
        "debounceMs": 2000
      }
    }
  },
  "plugins": {
    "entries": {
      "dual-model-trainer": {
        "enabled": false,
        "config": {
          "teacherModel": "yitong/qwen3-max",
          "studentModel": "ollama/jarvis",
          "parallelMode": true,
          "saveAllConversations": true,
          "minQualityDiff": 10
        }
      },
      "memory-core": {
        "enabled": false
      },
      "voice-call": {
        "enabled": false
      },
      "telegram": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      },
      "whatsapp": {
        "enabled": false
      },
      "lobster": {
        "enabled": false
      },
      "llm-task": {
        "enabled": false
      },
      "signal": {
        "enabled": false
      },
      "matrix": {
        "enabled": true
      },
      "msteams": {
        "enabled": false
      },
      "nostr": {
        "enabled": false
      },
      "twitch": {
        "enabled": false
      },
      "line": {
        "enabled": false
      },
      "mattermost": {
        "enabled": false
      },
      "nextcloud-talk": {
        "enabled": false
      },
      "tlon": {
        "enabled": false
      },
      "zalo": {
        "enabled": false
      },
      "zalouser": {
        "enabled": false
      },
      "imessage": {
        "enabled": false
      },
      "googlechat": {
        "enabled": false
      },
      "open-prose": {
        "enabled": false
      },
      "copilot-proxy": {
        "enabled": false
      },
      "openclaw-weixin": {
        "enabled": true
      },
      "ollama": {
        "enabled": true
      },
      "memory-wiki": {
        "enabled": false
      },
      "tavily": {
        "enabled": true
      },
      "clickclack": {
        "enabled": false
      },
      "admin-http-rpc": {
        "enabled": false
      },
      "active-memory": {
        "enabled": false
      },
      "discord": {
        "enabled": false
      },
      "feishu": {
        "enabled": false
      },
      "duckduckgo": {
        "enabled": true
      },
      "searxng": {
        "enabled": true
      },
      "sms": {
        "enabled": false
      },
      "webhooks": {
        "enabled": false
      },
      "irc": {
        "enabled": false
      },
      "bonjour": {
        "enabled": false
      },
      "oc-path": {
        "enabled": false
      },
      "thread-ownership": {
        "enabled": false
      },
      "workboard": {
        "enabled": false
      },
      "waltz-flight-assistant": {
        "enabled": false
      },
      "store-report-assistant": {
        "enabled": false
      },
      "google": {
        "enabled": false
      }
    }
  },
  "hooks": {
    "internal": {
      "enabled": true
    }
  },
  "tools": {
    "media": {
      "image": {
        "models": [
          {
            "prompt": "请用中文详细描述这张图片的内容，包括场景、物体、文字、颜色等。如果有多个物体，逐个描述。不超过300字。",
            "model": "glm-4.5-vision"
          }
        ],
        "attachments": {
          "mode": "all"
        },
        "enabled": true
      }
    }
  }
}
