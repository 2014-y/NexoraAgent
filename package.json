{
  "name": "ai-assistant",
  "version": "1.0.9",
  "description": "AI-v24.13.0 开源版 - 本地 AI 助手网关（基于 OpenClaw）",
  "keywords": [
    "ai",
    "assistant",
    "openclaw",
    "gateway",
    "mcp",
    "computer-use",
    "wechat",
    "whatsapp",
    "agnes-ai"
  ],
  "author": "AI助手",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/2014-y/AI-v24.13.0"
  },
  "main": "main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node start-gateway.js",
    "setup": "npm run install:deps && npm run init:config",
    "install:deps": "npm install -g openclaw@2026.6.11 open-computer-use@0.1.54",
    "init:config": "if not exist openclaw.json copy config\\openclaw.json.example openclaw.json",
    "doctor": "openclaw mcp doctor",
    "probe": "openclaw mcp probe",
    "logs": "type logs\\openclaw-%date%.log",
    "app:start": "electron .",
    "app:dist": "electron-builder --windows",
    "app:pack": "electron-packager . \"AI助手\" --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "dependencies": {
    "open-computer-use": "^0.1.54",
    "openclaw": "^2026.6.11"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.2014y.aigateway",
    "productName": "AI助手",
    "asar": false,
    "icon": "config/icon.ico",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "config/icon.ico",
      "publisherName": "AI助手",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI助手",
      "include": "config/installer.nsh",
      "installerIcon": "config/icon.ico",
      "uninstallerIcon": "config/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "patch_gateway.js",
      "renderer.js",
      "index.html",
      "index.css",
      "config/openclaw.json.example",
      "config/icon.jpg",
      "config/icon.png",
      "config/icon.ico",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/electron-packager/**/*",
      ".node-sandbox/**/*"
    ]
  }
}
