{
  "name": "ai-assistant",
  "version": "2.0.10",
  "description": "Nexora Agent",
  "keywords": [
    "ai",
    "assistant",
    "openclaw",
    "gateway",
    "mcp",
    "computer-use",
    "wechat",
    "whatsapp",
    "agnes-ai"
  ],
  "author": "Nexora Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/2014-y/ClawAI"
  },
  "main": "main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node start-gateway.js",
    "setup": "npm run install:deps && npm run init:config",
    "install:deps": "npm install -g openclaw@2026.6.11 open-computer-use@0.1.54",
    "init:config": "if not exist openclaw.json copy config\\openclaw.json.example openclaw.json",
    "doctor": "openclaw mcp doctor",
    "probe": "openclaw mcp probe",
    "logs": "type logs\\openclaw-%date%.log",
    "app:start": "electron .",
    "preapp:dist": "node scripts/pack-gateway-runtime.js && node scripts/prepare-acceleration-core.js && node patch_nsis.js",
    "app:dist": "electron-builder --windows nsis",
    "app:pack": "electron-packager . \"Nexora Agent\" --platform=win32 --arch=x64 --out=dist --overwrite",
    "pack:runtime": "node scripts/pack-gateway-runtime.js"
  },
  "dependencies": {
    "@openclaw/feishu": "2026.6.11",
    "@openclaw/matrix": "^2026.7.1",
    "@openclaw/qqbot": "^2026.7.1",
    "@openclaw/slack": "^2026.7.1",
    "@openclaw/voice-call": "^2026.7.1",
    "@openclaw/whatsapp": "^2026.7.1",
    "@tencent-weixin/openclaw-weixin": "2.4.6",
    "jsdom": "29.1.1",
    "node-pty": "^1.1.0",
    "open-computer-use": "0.1.54",
    "openclaw": "2026.7.1",
    "sherpa-onnx-node": "^1.13.4",
    "sherpa-onnx-win-x64": "^1.13.4",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.2014y.aigateway",
    "productName": "Nexora Agent",
    "asar": true,
    "compression": "store",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "forceCodeSigning": false,
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "**/node_modules/@openclaw/**",
      "**/node_modules/@tencent-weixin/**",
      "**/node_modules/sherpa-onnx-node/**",
      "**/node_modules/sherpa-onnx-win-x64/**",
      "**/tts-worker.js",
      "**/*.node",
      "**/*.dll"
    ],
    "icon": "config/icon.ico",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "config/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "config/icon.png"
    },
    "win": {
      "icon": "config/icon.ico",
      "publisherName": "Nexora Agent",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexora Agent",
      "runAfterFinish": false,
      "include": "config/installer.nsh",
      "installerIcon": "config/icon.ico",
      "uninstallerIcon": "config/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "extraResources": [
      {
        "from": "build-resources/gateway-runtime.tar",
        "to": "gateway-runtime.tar"
      },
      {
        "from": "build-resources/acceleration-core",
        "to": "acceleration-core"
      },
      {
        "from": "build-resources/voice-packs",
        "to": "voice-packs"
      }
    ],
    "files": [
      "main.js",
      "acceleration.js",
      "gateway-runtime.js",
      "home-resolve.js",
      "plugin-adapt.js",
      "openclaw-state.js",
      "gateway-auth.js",
      "openclaw-model-sync.js",
      "latency-tune.js",
      "token-usage-parse.js",
      "plugin-catalog.js",
      "gateway-boot-harden.js",
      "role-config.js",
      "voice-runtime.js",
      "tts-worker.js",
      "runtime-pack-manifest.js",
      "patch_gateway.js",
      "capture-desktop.ps1",
      "desktop-control.ps1",
      "weixin-direct-login.mjs",
      "preload.js",
      "renderer.js",
      "locales.js",
      "index.html",
      "index.css",
      "splash.html",
      "config/acceleration-core.json",
      "config/openclaw.json.example",
      "config/openclaw-templates/**/*",
      "config/icon.jpg",
      "config/icon.png",
      "config/icon.ico",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/electron-packager/**/*",
      "!node_modules/openclaw/**/*",
      "!node_modules/@openclaw/**/*",
      "!node_modules/@tencent-weixin/**/*",
      "!node_modules/open-computer-use/**/*",
      "!node_modules/**/{test,tests,__tests__,docs,doc,example,examples,coverage,.github,man}/**",
      "!node_modules/**/*.{md,markdown,map,ts,tsx}",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/LICENCE*",
      "plugins/**/*",
      "builtin-asr/**/*",
      "!extensions/**/*",
      "!.node-sandbox/**/*"
    ]
  },
  "allowScripts": {
    "node-pty@1.1.0": true,
    "protobufjs@7.6.3": true,
    "tree-sitter-bash@0.25.1": true,
    "@google/genai@2.10.0": true
  }
}
